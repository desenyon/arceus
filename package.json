{
  "name": "arceus",
  "version": "0.1.0",
  "description": "Arceus is a fast, terminal-native, collaboration-first coding agent.",
  "type": "module",
  "bin": {
    "arceus": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/index.ts",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:watch": "tsx --watch src/cli/index.ts"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
